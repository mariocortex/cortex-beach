# ============================================
# CLIENT — produção (Hostinger VPS)
# ============================================
# Copie este arquivo para .env.production antes de rodar `npm run build`.
# O PORT só afeta `npm run serve` (fallback se não usar Nginx).

PORT=5000

# URL PÚBLICA do backend. Em produção aponta para o domínio/IP do VPS.
# Exemplos:
#   REACT_APP_API_URL=https://api.cortexbeach.com
#   REACT_APP_API_URL=http://123.45.67.89:5001
REACT_APP_API_URL=https://api.seudominio.com
